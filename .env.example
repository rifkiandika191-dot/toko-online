# Salin file ini jadi .env untuk menjalankan secara lokal.
# Di Railway, isi nilai-nilai ini lewat tab "Variables" (JANGAN commit .env asli).

# Koneksi PostgreSQL. Di Railway, ambil dari service Postgres -> Variables -> DATABASE_URL.
# Tip: pakai ${{ Postgres.DATABASE_URL }} agar otomatis terhubung antar service.
DATABASE_URL=postgresql://user:password@host:5432/railway

# Set "true" hanya jika memakai URL publik Postgres (butuh SSL). Untuk koneksi
# internal Railway, biarkan kosong / false.
DATABASE_SSL=false

# Password untuk masuk ke halaman /admin.html. WAJIB diganti!
ADMIN_PASSWORD=ganti-password-kuat

# Kunci rahasia untuk menandatangani token login admin. WAJIB diganti (acak panjang)!
JWT_SECRET=ganti-dengan-teks-acak-panjang

# Folder penyimpanan gambar upload. Di Railway: pasang Volume mount /data,
# lalu set UPLOAD_DIR=/data/uploads. Lokal: kosongkan (default ./uploads).
# UPLOAD_DIR=/data/uploads

# (Opsional) Kunci API Claude untuk fitur "buat deskripsi otomatis dari foto".
# Ambil di https://console.anthropic.com → API Keys. Tanpa ini, tombol AI nonaktif
# tapi fitur lain tetap jalan. Pakai model claude-haiku-4-5 (murah).
ANTHROPIC_API_KEY=

# Port (Railway mengisi otomatis; lokal default 3000).
# PORT=3000
